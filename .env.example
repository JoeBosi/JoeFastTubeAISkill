# JoeFastTubeAI — Whisper API configuration (OPTIONAL)
#
# A key is needed ONLY to transcribe videos that have NO captions.
# Most YouTube videos already have captions, so you may never need this.
# Set just ONE of the two below (Groq is preferred: free tier, fast).
#
# How to use this file:
#   mkdir -p ~/.config/JoeFastTubeAI
#   cp .env.example ~/.config/JoeFastTubeAI/.env
#   chmod 600 ~/.config/JoeFastTubeAI/.env
#   # then open ~/.config/JoeFastTubeAI/.env and paste your key after the =
#
# Get a Groq key:    https://console.groq.com/keys        (starts with gsk_)
# Get an OpenAI key: https://platform.openai.com/api-keys  (starts with sk-)
#
# Format: KEY=value — no quotes, no spaces around the "=". Never commit your real key.

GROQ_API_KEY=
OPENAI_API_KEY=
